# Copy file ini menjadi .env dan sesuaikan nilainya

# Port server (default: 3000)
PORT=3000

# Environment (development/production)
NODE_ENV=development

# Secret key untuk API (optional, untuk fitur admin auth di masa depan)
API_SECRET=your-secret-key-here

# CORS origin (pisahkan dengan koma untuk multiple origins)
# Gunakan * untuk mengizinkan semua origin (tidak disarankan untuk production)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
